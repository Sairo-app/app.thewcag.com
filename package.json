{
  "name": "accessibility-build-app",
  "private": true,
  "version": "2.2.0",
  "scripts": {
    "dev": "pnpm --filter @accessibility-build/desktop dev",
    "build": "pnpm --filter @accessibility-build/desktop build",
    "build:web": "pnpm --filter @thewcag/web build",
    "typecheck": "pnpm --filter @accessibility-build/desktop typecheck && pnpm --filter @thewcag/web typecheck",
    "test": "pnpm --filter @accessibility-build/a11y-core test",
    "verify": "pnpm test && pnpm typecheck && pnpm --filter @accessibility-build/desktop build:vite && pnpm build:web"
  },
  "packageManager": "pnpm@9.15.4"
}
