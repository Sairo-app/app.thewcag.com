# app.thewcag.com: required environment
# Public base URL (used for share links, deep-link callbacks, OG images)
NEXT_PUBLIC_APP_URL=https://app.thewcag.com
NEXT_PUBLIC_PRIVACY_EMAIL=privacy@thewcag.com

# Auth.js: generate with: openssl rand -base64 32
AUTH_SECRET=
# Canonical Auth.js origin. Required in production so callback URLs never rely
# on an untrusted forwarded Host header.
AUTH_URL=https://app.thewcag.com

# Magic-link email via Resend (https://resend.com)
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM="TheWCAG <login@thewcag.com>"

# Optional comma-separated emails allowed to access /admin (unset = no admins)
ADMIN_EMAILS=

# Optional AI-assisted finding authoring. When OPENAI_API_KEY is empty, the
# endpoint returns a clear unavailable response and the extension uses its local
# deterministic draft. GPT-5.6 Terra balances quality and cost for this bounded
# multimodal structured-output task; override only after representative evals.
OPENAI_API_KEY=
OPENAI_FINDING_MODEL=gpt-5.6-terra
AI_SAFETY_SALT=

# Dodo Payments (the only billing provider). Product IDs must be recurring
# monthly and annual products created in the same Dodo business/environment.
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_BUSINESS_ID=
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PRO_MONTHLY_PRODUCT_ID=
DODO_PRO_ANNUAL_PRODUCT_ID=
# Used by the protected reconciliation/retention route.
BILLING_RECONCILE_SECRET=

# Public price copy and server-enforced Pro allowances.
NEXT_PUBLIC_PRO_MONTHLY_PRICE_USD=19
NEXT_PUBLIC_PRO_ANNUAL_PRICE_USD=190
PRO_AI_GENERATIONS_PER_PERIOD=150
PRO_AI_GENERATIONS_PER_HOUR=20
PRO_HOSTED_REPORT_LIMIT=100
PRO_STORAGE_QUOTA_BYTES=1073741824

# Postgres (metadata + Auth.js tables)
DATABASE_URL=postgres://user:pass@host:5432/thewcag
# Non-Docker production platforms should run `pnpm --filter @thewcag/web db:migrate`
# during deployment. Set this only when a platform cannot run a deploy command.
RUN_STARTUP_MIGRATIONS=false

# Cloudflare R2 (screenshot image blobs) - S3-compatible
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=thewcag-reports
# Keep the bucket private. Images are served through entitlement-aware app
# routes so expired or revoked report links cannot bypass access checks.
