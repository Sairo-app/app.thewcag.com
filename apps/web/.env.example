# app.thewcag.com: required environment
# Public base URL (used for share links, deep-link callbacks, OG images)
NEXT_PUBLIC_APP_URL=https://app.thewcag.com

# Auth.js: generate with: openssl rand -base64 32
AUTH_SECRET=

# Magic-link email via Resend (https://resend.com)
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM="TheWCAG <login@thewcag.com>"

# Optional comma-separated emails allowed to access /admin (unset = no admins)
ADMIN_EMAILS=

# Postgres (metadata + Auth.js tables)
DATABASE_URL=postgres://user:pass@host:5432/thewcag

# Cloudflare R2 (screenshot image blobs) - S3-compatible
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=thewcag-reports
# Public bucket URL - a custom domain (https://cdn.thewcag.com) or the managed
# r2.dev URL. When set, images are served from Cloudflare's CDN, not proxied.
R2_PUBLIC_URL=https://cdn.thewcag.com
