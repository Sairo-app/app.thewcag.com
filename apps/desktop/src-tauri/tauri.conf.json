{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Accessibility Build",
  "version": "1.4.0",
  "identifier": "build.accessibility.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev:vite",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Accessibility.build",
        "width": 460,
        "height": 720,
        "minWidth": 420,
        "minHeight": 560,
        "resizable": true,
        "maximizable": false,
        "visible": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "windowEffects": {
          "effects": ["underWindowBackground"],
          "state": "followsWindowActiveState"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://accessibility.build/downloads/desktop/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQyMTQ0MkNERTBBOTk0RgpSV1JQbVFyZUxFUWhCSjdZVTlPMkg2clJJYWtDZU1KeURRLzlYaWUwZVF6VmtZTXFleWVoQ3ZZbAo="
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
