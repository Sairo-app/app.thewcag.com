{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TheWCAG",
  "version": "2.4.0",
  "identifier": "com.thewcag.app",
  "build": {
    "beforeDevCommand": "pnpm dev:vite",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "TheWCAG",
        "width": 900,
        "height": 740,
        "minWidth": 720,
        "minHeight": 580,
        "resizable": true,
        "maximizable": true,
        "visible": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "windowEffects": {
          "effects": ["underWindowBackground"],
          "state": "followsWindowActiveState"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/Sairo-app/app.thewcag.com/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQyMTQ0MkNERTBBOTk0RgpSV1JQbVFyZUxFUWhCSjdZVTlPMkg2clJJYWtDZU1KeURRLzlYaWUwZVF6VmtZTXFleWVoQ3ZZbAo="
    },
    "deep-link": {
      "desktop": {
        "schemes": ["thewcag"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
