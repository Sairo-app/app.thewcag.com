{
  "name": "@accessibility-build/desktop",
  "productName": "TheWCAG",
  "version": "3.0.7",
  "description": "A production accessibility audit workstation for macOS and Windows.",
  "author": "TheWCAG",
  "homepage": "https://app.thewcag.com",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:vite": "vite --config vite.config.ts",
    "build": "pnpm typecheck && electron-vite build",
    "build:vite": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "pnpm build && electron-builder --dir",
    "dist": "pnpm build && electron-builder",
    "dist:mac": "pnpm build && electron-builder --mac --universal",
    "dist:win": "pnpm build && electron-builder --win --x64",
    "icons": "node ../../scripts/generate-desktop-icons.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "electron-updater": "^6.8.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@accessibility-build/a11y-core": "workspace:*",
    "@accessibility-build/audit-contracts": "workspace:*",
    "@tailwindcss/vite": "^4.1.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "axe-core": "^4.12.1",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.3.0",
    "vitest": "^4.1.10"
  }
}
