# Optional canonical web origin used by desktop sign-in, hosted reports, and
# anonymous funnel telemetry. Production builds default to app.thewcag.com;
# set this for a trusted local or staging web deployment.
MAIN_VITE_SITE_URL=https://app.thewcag.com

# Published Chrome extension ID permitted to launch the native host.
THEWCAG_EXTENSION_ID=
