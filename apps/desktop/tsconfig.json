{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "types": ["vite/client", "node", "electron"]
  },
  "include": [
    "electron/**/*.ts",
    "src/main.tsx",
    "src/env.d.ts",
    "src/app/**/*.ts",
    "src/app/**/*.tsx",
    "src/shared/**/*.ts",
    "src/lib/annotate/**/*.ts",
    "electron.vite.config.ts",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}
